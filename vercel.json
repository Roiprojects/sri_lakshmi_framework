{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    { "src": "/api/(.*)", "dest": "/server.js" },
    { "src": "/admin", "dest": "/public/login.html" },
    { "src": "/dashboard", "dest": "/public/admin.html" },
    { "src": "/gallery", "dest": "/public/gallery.html" },
    { "src": "/about", "dest": "/public/about.html" },
    { "src": "/contact", "dest": "/public/contact.html" },
    { "src": "/frames", "dest": "/public/frames.html" },
    { "src": "/testimonials", "dest": "/public/testimonials.html" },
    { "src": "/(.*)", "dest": "/server.js" }
  ]
}
